// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/python
{
	"name": "ovpncp",
	// Or use a Dockerfile or Docker Compose file. More info: https://containers.dev/guide/dockerfile
	"image": "mcr.microsoft.com/devcontainers/python:3.14-trixie",

	// Features to add to the dev container. More info: https://containers.dev/features.
	"features": {
		"ghcr.io/devcontainers-extra/features/fish-apt-get:1": {},
		"ghcr.io/devcontainers-extra/features/starship:1": {},
		"ghcr.io/devcontainers/features/node:1": {}
	},

	// Workaround for GIT inside DEV container.
	"mounts": [
		"type=bind,source=${localEnv:HOME}/.ssh,target=/home/vscode/.ssh,readonly",
		"type=bind,source=${localEnv:HOME}/.gemini,target=/home/vscode/.gemini",
		"type=bind,source=${localEnv:HOME}/.azure,target=/home/vscode/.azure"
	],

	// Use 'forwardPorts' to make a list of ports inside the container available locally.
	"forwardPorts": [8000],

	// Use 'postCreateCommand' to run commands after the container is created.
	"postCreateCommand": "bash .devcontainer/post-create.sh",

	// Configure tool-specific properties.	
	"customizations": {
		"vscode": {
			"extensions": [
				"ms-python.python",
				"ms-python.debugpy",
				"ms-python.vscode-python-envs",
				"ms-python.vscode-pylance",
				"charliermarsh.ruff",
				"tamasfe.even-better-toml",
				"google.gemini-cli-vscode-ide-companion"
			]
		}
	}

	// Uncomment to connect as root instead. More info: https://aka.ms/dev-containers-non-root.
	// "remoteUser": "root"
}
